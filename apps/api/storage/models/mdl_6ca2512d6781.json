      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "scurve(period_index, issuance_start, issuance_peak, issuance_ramp)"
      }
    },
    {
      "id": "itm_374bb5464500",
      "name": "prev_preferred",
      "category": "other",
      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "if(prior(preferred_notional) == 0, preferred_start, prior(preferred_notional))"
      }
    },
    {
      "id": "itm_9b74cd79cc3a",
      "name": "preferred_raise",
      "category": "other",
      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "max(0, preferred_raise_target)"
      }
    },
    {
      "id": "itm_c87c26a4ace1",
      "name": "preferred_notional",
      "category": "kpi",
      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "prev_preferred + preferred_raise"
      }
    },
    {
      "id": "itm_fe6c83dedaba",
      "name": "preferred_dividend",
      "category": "kpi",
      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "preferred_notional * div_rate / 4"
      }
    },
    {
      "id": "itm_57c65dc043f2",
      "name": "div_coverage",
      "category": "kpi",
      "unit": "ratio",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "if(preferred_dividend == 0, 0, preferred_raise / preferred_dividend)"
      }
    },
    {
      "id": "itm_fc116bc12244",
      "name": "dividend_shortfall",
      "category": "other",
      "unit": "currency",
      "section": "financing",
      "definition": {
        "kind": "formula",
        "expression": "max(0, preferred_dividend - preferred_raise)"
      }
    },
    {
      "id": "itm_c08331014c84",
      "name": "cash",
      "category": "kpi",
      "unit": "currency",
      "section": "reserve",
      "definition": {
        "kind": "formula",
        "expression": "max(0, cash_start - cumulative(dividend_shortfall))"
      }
    },
    {
      "id": "itm_534b3b3e0691",
      "name": "net_preferred_capital",
      "category": "other",
      "unit": "currency",
      "section": "reserve",
      "definition": {
        "kind": "formula",
        "expression": "max(0, preferred_raise - preferred_dividend)"
      }
    },
    {
      "id": "itm_4b3f384e2fe7",
      "name": "btc_bought",
      "category": "other",
      "unit": "count",
      "section": "reserve",
      "definition": {
        "kind": "formula",
        "expression": "(net_preferred_capital + atm_raise) * 1000000 / btc_price"
      }
    },
    {
      "id": "itm_899475affea3",
      "name": "btc_held",
      "category": "kpi",
      "unit": "count",
      "section": "reserve",
      "definition": {
        "kind": "formula",
        "expression": "if(prior(btc_held) == 0, btc_held_start, prior(btc_held)) + btc_bought"
      }
    },
    {
      "id": "itm_7951a709f251",
      "name": "new_shares",
      "category": "other",
      "unit": "count",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "atm_raise / max(co_price, 1)"
      }
    },
    {
      "id": "itm_a26384988927",
      "name": "common_shares",
      "category": "kpi",
      "unit": "count",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "if(prior(common_shares) == 0, shares_start, prior(common_shares)) + new_shares"
      }
    },
    {
      "id": "itm_809e97289558",
      "name": "senior_debt",
      "category": "other",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "debt_notional"
      }
    },
    {
      "id": "itm_ae2d6ce7c012",
      "name": "convert_claim",
      "category": "other",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "convertible_debt * (1 - convert_as_equity)"
      }
    },
    {
      "id": "itm_d167e0b7ba69",
      "name": "nav_to_common",
      "category": "kpi",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "reserve + cash + other_holdings - senior_debt - convert_claim - preferred_notional"
      }
    },
    {
      "id": "itm_e1d89592ffac",
      "name": "nav_per_share",
      "category": "kpi",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "nav_to_common / common_shares"
      },
      "scale": 1
    },
    {
      "id": "itm_41a5a9520215",
      "name": "mnav",
      "category": "kpi",
      "unit": "ratio",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "mnav_path"
      }
    },
    {
      "id": "itm_0d44090b1978",
      "name": "co_price",
      "category": "kpi",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "max(nav_per_share, 0) * mnav"
      },
      "scale": 1
    },
    {
      "id": "itm_31c0294cd1e3",
      "name": "co_mcap",
      "category": "kpi",
      "unit": "currency",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "co_price * common_shares"
      }
    },
    {
      "id": "itm_39b198debe6d",
      "name": "implied_leverage",
      "category": "kpi",
      "unit": "ratio",
      "section": "equity",
      "definition": {
        "kind": "formula",
        "expression": "if(nav_to_common <= 0, 99, reserve / nav_to_common)"
      }
    }
